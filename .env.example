# Copy to .env and fill in. .env is gitignored -- never commit real values.

# Telegram alerting (optional: if unset, alerts are logged only)
TG_TOKEN=your-telegram-bot-token
TG_CHAT_ID=your-chat-id

# Detection parameters (optional -- sensible defaults in config)
DEPTH_USD=500000
SPREAD_THRESHOLD_PCT=1.5
VELOCITY_THRESHOLD_PCT_MIN=0.5
FEE_BUFFER_PCT=0.2
CONFIRM_SECONDS=180
MIN_SAMPLES=6
MAX_FETCH_WINDOW_S=2.0
BENCHMARK_TOLERANCE_PCT=0.5
POLL_INTERVAL_S=20
HEARTBEAT_INTERVAL_S=3600
DATA_LOG_PATH=snapshots.csv
